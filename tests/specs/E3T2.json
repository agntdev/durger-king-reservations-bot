[
  {
    "name": "guest can reschedule booking via inline button",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:10:00", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "party:2", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }, { "method": "sendMessage" }]
      },
      {
        "send": { "text": "Alex Guest" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "+15551234567" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "booking:reschedule:DK-0001", "messageId": 6 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Choose a new date for your rescheduled reservation.\n\nJune 2026"
            }
          }
        ]
      },
      {
        "send": { "callback": "cal:date:2026-07-02", "messageId": 6 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:11:00", "messageId": 6 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "party:3", "messageId": 6 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Booking DK-0001 rescheduled to 2026-07-02 at 11:00 for 3 guests."
            }
          }
        ]
      }
    ]
  }
]