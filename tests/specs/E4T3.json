[
  {
    "name": "new booking notifies the owner",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:10:00", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "party:2", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }, { "method": "sendMessage" }]
      },
      {
        "send": { "text": "Alex Guest" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "+15551234567" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "New booking\n\nBooking ID: DK-0001\nGuest: Alex Guest\nPhone: +15551234567\nDate: 2026-07-01\nTime: 10:00\nParty size: 2"
            }
          },
          { "method": "sendMessage" },
          { "method": "sendMessage" }
        ]
      }
    ]
  },
  {
    "name": "cancelled booking notifies the owner",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:10:00", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "party:2", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }, { "method": "sendMessage" }]
      },
      {
        "send": { "text": "Alex Guest" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "+15551234567" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "booking:cancel:DK-0001", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "Booking cancelled\n\nBooking ID: DK-0001\nGuest: Alex Guest\nDate: 2026-07-01\nTime: 10:00\nParty size: 2"
            }
          },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]