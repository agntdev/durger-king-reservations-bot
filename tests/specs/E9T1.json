[
  {
    "name": "date selection shows compact hour grid",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Step 2 of 4 — Choose a time\n\nDate: 2026-07-01\n\nChoose an available time slot:",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "10 ▶", "callback_data": "slot:hour:10" },
                    { "text": "11 ▶", "callback_data": "slot:hour:11" },
                    { "text": "12 ▶", "callback_data": "slot:hour:12" },
                    { "text": "13 ▶", "callback_data": "slot:hour:13" }
                  ],
                  [
                    { "text": "14 ▶", "callback_data": "slot:hour:14" },
                    { "text": "15 ▶", "callback_data": "slot:hour:15" },
                    { "text": "16 ▶", "callback_data": "slot:hour:16" },
                    { "text": "17 ▶", "callback_data": "slot:hour:17" }
                  ],
                  [
                    { "text": "18 ▶", "callback_data": "slot:hour:18" },
                    { "text": "19 ▶", "callback_data": "slot:hour:19" },
                    { "text": "20 ▶", "callback_data": "slot:hour:20" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
