[
  {
    "name": "date selection shows available time slots",
    "steps": [
      {
        "send": {
          "text": "/reserve"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "cal:date:2026-07-01",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Step 2 of 4 — Choose a time\n\nDate: 2026-07-01\n\nChoose an available time slot:"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "time slot selection confirms chosen slot",
    "steps": [
      {
        "send": {
          "text": "/reserve"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "cal:date:2026-07-01",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "slot:10:00",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Step 3 of 4 — Choose party size\n\nDate: 2026-07-01\nTime: 10:00\n\nHow many guests will be dining?"
            }
          }
        ]
      }
    ]
  }
]
