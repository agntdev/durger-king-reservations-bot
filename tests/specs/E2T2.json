[
  {
    "name": "owner checknoshows flags unarrived booking and notifies owner",
    "steps": [
      {
        "send": {
          "text": "/reserve"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "cal:date:2026-07-01",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "slot:10:00",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "party:2",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          },
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "Alex Guest"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "+15551234567"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "/checknoshows"
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No-show flagged\n\nBooking ID: DK-0001\nGuest: Alex Guest\nDate: 2026-07-01\nTime: 10:00\nParty size: 2\nThe guest was not marked arrived within 30 minutes of the start time."
            }
          }
        ]
      }
    ]
  }
]
