[
  {
    "name": "time slot selection prompts party size choices",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:10:00", "messageId": 1 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "How many guests will be dining?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "valid party size selection is confirmed",
    "steps": [
      {
        "send": { "text": "/reserve" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "cal:date:2026-07-01", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "slot:10:00", "messageId": 1 },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "party:2", "messageId": 1 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Party size: 2"
            }
          }
        ]
      }
    ]
  }
]