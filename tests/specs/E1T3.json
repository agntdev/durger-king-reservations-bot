[
  {
    "name": "time slot selection prompts party size choices",
    "steps": [
      {
        "send": {
          "text": "/reserve"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "cal:date:2026-07-01",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "slot:10:00",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Step 3 of 4 — Choose party size\n\nDate: 2026-07-01\nTime: 10:00\n\nHow many guests will be dining?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "valid party size selection is confirmed",
    "steps": [
      {
        "send": {
          "text": "/reserve"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "cal:date:2026-07-01",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "slot:10:00",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText"
          }
        ]
      },
      {
        "send": {
          "callback": "party:2",
          "messageId": 1
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Date: 2026-07-01\nTime: 10:00\nParty size: 2"
            }
          }
        ]
      }
    ]
  }
]
